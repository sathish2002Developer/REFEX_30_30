# Copy to `.env` in this folder and adjust values.

# Required in production — JWT signing for /auth/login and /api/admin
APP_KEY=b1111111111111111111111111111111

# Optional: used for some API flows
# API_KEY=

# Optional: default password when creating users via API
# DEFAULT_PASSWORD=

# Wall sign-in: default password for new wall users (falls back to DEFAULT_PASSWORD)
# WALL_DEFAULT_PASSWORD=RefexWall2026!

# Base URL for wall password reset links (falls back to request Origin, then http://localhost:3000)
# WALL_FRONT_END_URL=http://localhost:3000
